# ════════════════════════════════════════════════
# DompetKu — Environment Variables
# Copy ke .env, JANGAN commit file .env ke Git
# ════════════════════════════════════════════════

# Supabase (WAJIB)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_service_role_key_here

# PostgreSQL untuk session store (OPSIONAL tapi sangat direkomendasikan)
# Gunakan Connection String dari Supabase: Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# Admin dashboard credentials (WAJIB DIGANTI!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ganti_password_kuat_disini

# Session secret (min 32 karakter random) - WAJIB DIGANTI!
SESSION_SECRET=ganti_dengan_random_string_32_karakter_minimal_ya

# Hugging Face untuk voice transcription (OPSIONAL)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxx

# Railway / Production
NODE_ENV=production
PORT=3000